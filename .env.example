# Backend - set these in Vercel Environment Variables
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/document-vault
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret
CORS_ORIGIN=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Frontend - set this in Vercel Environment Variables  
# (leave empty to default to same-origin /api/v1)
VITE_API_URL=
